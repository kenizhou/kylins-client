{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "bash .claude/hooks/simplify-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking /simplify gate before push"
          }
        ]
      }
    ]
  }
}
