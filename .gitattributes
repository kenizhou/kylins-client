# Normalize text files to LF in the repo and working tree.
# This makes Prettier's `endOfLine: "lf"` reliable on Windows (overrides
# core.autocrlf, which would otherwise check files out as CRLF and break
# `prettier --check`).
* text=auto eol=lf

# Explicit LF for source/config files.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.sh text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
