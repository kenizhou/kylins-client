+
+        let sink = Arc::new(TestSink::new());
+        let engine = SyncEngine::new(pool.clone(), sink.clone());
+
+        let folder = RemoteFolder {
+            remote_id: "INBOX".into(),
+            name: "INBOX".into(),
+            delimiter: "/".into(),
+            role: Some("inbox".into()),
