+             VALUES (?, ?, 'imap', 1, 0, 0, strftime('%s','now'), strftime('%s','now'))",
+        )
+        .bind(id)
+        .bind(format!("{id}@x.com"))
+        .execute(pool)
+        .await
+        .unwrap();
+    }
+
