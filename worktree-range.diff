+        .bind(if is_read { 1 } else { 0 })
+        .execute(pool)
+        .await
+        .unwrap();
+        sqlx::query(
+            "INSERT INTO thread_labels (account_id, thread_id, label_id)
+             VALUES (?, ?, ?)",
+        )
+        .bind(account_id)
+        .bind(thread_id)
+        .bind(label_id)
+        .execute(pool)
+        .await
+        .unwrap();
+    }
