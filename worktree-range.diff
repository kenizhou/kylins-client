+    pub refresh_token: Option<String>,
+    #[serde(default)]
+    pub token_expires_at: Option<i64>,
+    #[serde(default)]
+    pub is_active: Option<bool>,
+    #[serde(default)]
+    pub is_default: Option<bool>,
+    #[serde(default)]
+    pub sort_order: Option<i64>,
+
+    // IMAP / SMTP
+    #[serde(default)]
