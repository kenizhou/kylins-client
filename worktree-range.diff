+        assert_eq!(parent_of("A.B", "."), Some("A".into()));
+        assert_eq!(parent_of("flat", "/"), None);
+        assert_eq!(parent_of("anything", ""), None);
+    }
+
+    #[test]
+    fn uid_set_joins_comma() {
